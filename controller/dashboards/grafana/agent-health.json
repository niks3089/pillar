          "color": { "mode": "thresholds" },
          "mappings": [{ "options": { "0": { "text": "DISCONNECTED", "color": "#f44336" }, "1": { "text": "CONNECTED", "color": "#4caf50" } }, "type": "value" }]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "title": "Controller Link",
      "type": "stat",
      "targets": [{ "expr": "pillar_controller_connected{node_id=\"$node_id\"}", "legendFormat": "", "refId": "A" }]
