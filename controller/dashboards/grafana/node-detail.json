        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#f44336", "value": null },
              { "color": "#4caf50", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "text": "UNHEALTHY" }, "1": { "text": "HEALTHY" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
