#!/usr/bin/env bash
set -euo pipefail
echo "=== Pillar: Provisioning Firedancer {{version}} on {{cluster}} ==="

DOWNLOAD_URL="{{download_url}}"
STAGING="/tmp/pillar-staging"
rm -rf "$STAGING"

# Skip if fdctl is already at the requested version.
if [ -x "{{binary_path}}" ]; then
  CURRENT=$("{{binary_path}}" version 2>/dev/null | grep -oP '\d+\.\d+\.\d+(-[a-zA-Z0-9.]+)?' | head -1 || true)
  if [ "$CURRENT" = "{{version}}" ]; then
    echo "Binary {{binary_path}} already at v{{version}}, skipping install"
  else
    echo "fdctl exists but version $CURRENT != {{version}}, will reinstall"
    CURRENT=""
  fi
fi

if [ -z "${CURRENT:-}" ]; then
  if [ -n "$DOWNLOAD_URL" ]; then
    mkdir -p "$STAGING"
    echo "Downloading fdctl from $DOWNLOAD_URL..."
    curl -sSL -o "$STAGING/fdctl" "$DOWNLOAD_URL"
    SHA="{{sha256}}"
    if [ -n "$SHA" ]; then
      echo "$SHA  $STAGING/fdctl" | sha256sum -c
      echo "SHA256 verified"
    fi
    sudo install -m 755 "$STAGING/fdctl" {{binary_path}}
  else
    # Firedancer does not publish standalone fdctl binaries — build from source.
    echo "No download_url provided, building Firedancer v{{version}} from source..."
    BUILD_DIR="/tmp/firedancer-build"
    rm -rf "$BUILD_DIR"

    # Base build tools; Firedancer's deps.sh installs the rest.
    if ! dpkg -s build-essential clang cmake gcc make pkg-config >/dev/null 2>&1; then
      echo "Installing base build tools..."
      sudo apt-get update -qq && sudo apt-get install -y -qq build-essential clang cmake gcc make pkg-config
    fi

    git clone --recurse-submodules --depth 1 --branch v{{version}} https://github.com/firedancer-io/firedancer.git "$BUILD_DIR"
    cd "$BUILD_DIR"

    # deps.sh fetches/builds vendored libraries; auto-accept OS package installs.
    echo "Installing Firedancer dependencies (deps.sh)..."
    FD_AUTO_INSTALL_PACKAGES=1 ./deps.sh +dev install

    echo "Building fdctl (this may take 20-40 minutes)..."
    make -j fdctl

    FDCTL_BIN=$(find "$BUILD_DIR/build" -name fdctl -type f | head -1)
    if [ -z "$FDCTL_BIN" ]; then
      echo "ERROR: fdctl not found after build" >&2
      exit 1
    fi
    sudo install -m 755 "$FDCTL_BIN" {{binary_path}}
    cd /
    rm -rf "$BUILD_DIR"
    echo "Built and installed fdctl v{{version}}"
  fi
fi
echo "Binary ready at {{binary_path}}"

# Stop existing service if running
sudo systemctl stop {{old_service_name}} 2>/dev/null || true

# Write Firedancer TOML config
sudo mkdir -p /etc/pillar
sudo tee /etc/pillar/validator.toml > /dev/null <<'TOML'
{{firedancer_toml}}
TOML
echo "Wrote /etc/pillar/validator.toml"

# Initialize the runtime environment (hugepages, XDP, workspaces). Requires root.
# Non-fatal: surfaces clearly if the host's NIC/driver does not support AF_XDP.
echo "Running fdctl configure init all..."
if ! sudo {{binary_path}} configure init all --config /etc/pillar/validator.toml; then
  echo "WARNING: 'fdctl configure init' failed — the host NIC/driver may not support AF_XDP," >&2
  echo "         or hugepages are unavailable. Firedancer cannot run until this is resolved." >&2
fi

# Write systemd unit
sudo tee /etc/systemd/system/{{service_name}}.service > /dev/null <<'UNIT'
[Unit]
Description=Solana Validator (firedancer)
After=network.target
{{start_limit_line}}

[Service]
Type=simple
User=sol
ExecStart={{exec_start}}
Restart=on-failure
RestartSec={{restart_sec}}
LimitNOFILE=1000000
LimitMEMLOCK=infinity
{{log_rate_limit_line}}
{{environment_lines}}

[Install]
WantedBy=multi-user.target
UNIT

sudo systemctl daemon-reload
sudo systemctl enable --now {{service_name}}
echo "Service {{service_name}} started"

# Update agent config
CONFIG="${PILLAR_AGENT_CONFIG:-/etc/pillar/agent.yaml}"
{{agent_config_sed_commands}}

echo "=== Provision complete ==="

# Restart agent for config reload (deferred so script result can be reported)
(sleep 3 && sudo systemctl restart pillar-agent) &
