{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#2196f3", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Total Nodes",
      "type": "stat",
      "targets": [{ "expr": "count(pillar_node_healthy)", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#4caf50", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Healthy",
      "type": "stat",
      "targets": [{ "expr": "count(pillar_node_healthy == 1) or vector(0)", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#2196f3", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 9,
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Avg CPU %",
      "type": "stat",
      "targets": [{ "expr": "avg(pillar_system_cpu_usage_percent)", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#2196f3", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 10,
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Avg Memory %",
      "type": "stat",
      "targets": [{ "expr": "avg(pillar_system_memory_used_bytes / pillar_system_memory_total_bytes * 100)", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "healthy" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "#f44336", "value": null }, { "color": "#4caf50", "value": 1 }] } },
              { "id": "mappings", "value": [{ "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "slots_behind" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "#4caf50", "value": null }, { "color": "#ffc107", "value": 50 }, { "color": "#f44336", "value": 200 }] } },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "cpu %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "#4caf50", "value": null }, { "color": "#ffc107", "value": 70 }, { "color": "#f44336", "value": 90 }] } },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "memory %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "#4caf50", "value": null }, { "color": "#ffc107", "value": 70 }, { "color": "#f44336", "value": 90 }] } },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "disk %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "#4caf50", "value": null }, { "color": "#ffc107", "value": 80 }, { "color": "#f44336", "value": 90 }] } },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-text" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "id": 4,
      "options": { "showHeader": true, "sortBy": [{ "desc": false, "displayName": "node_id" }] },
      "title": "Node List",
      "type": "table",
      "targets": [
        { "expr": "max by (node_id) (pillar_node_healthy)", "format": "table", "instant": true, "refId": "healthy" },
        { "expr": "max by (node_id) (pillar_node_slots_behind)", "format": "table", "instant": true, "refId": "slots_behind" },
        { "expr": "max by (node_id) (pillar_system_cpu_usage_percent)", "format": "table", "instant": true, "refId": "cpu" },
        { "expr": "max by (node_id) (pillar_system_memory_used_bytes) / max by (node_id) (pillar_system_memory_total_bytes) * 100", "format": "table", "instant": true, "refId": "memory_pct" },
        { "expr": "max by (node_id) (pillar_system_disk_used_bytes) / max by (node_id) (pillar_system_disk_total_bytes) * 100", "format": "table", "instant": true, "refId": "disk_pct" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": {
              "Value #healthy": "healthy",
              "Value #slots_behind": "slots_behind",
              "Value #cpu": "cpu %",
              "Value #memory_pct": "memory %",
              "Value #disk_pct": "disk %"
            }
          }
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false, "axisLabel": "slots", "drawStyle": "line",
            "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "never",
            "spanNulls": false, "stacking": { "mode": "none" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Slots Behind per Node",
      "type": "timeseries",
      "targets": [{ "expr": "pillar_node_slots_behind", "legendFormat": "{{ node_id }}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false, "axisLabel": "%", "drawStyle": "line",
            "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "never",
            "spanNulls": false, "stacking": { "mode": "none" }
          },
          "max": 100, "min": 0, "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "CPU Usage per Node",
      "type": "timeseries",
      "targets": [{ "expr": "pillar_system_cpu_usage_percent", "legendFormat": "{{ node_id }}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false, "axisLabel": "%", "drawStyle": "line",
            "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "never",
            "spanNulls": false, "stacking": { "mode": "none" }
          },
          "max": 100, "min": 0, "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Memory Usage % per Node",
      "type": "timeseries",
      "targets": [{ "expr": "pillar_system_memory_used_bytes / pillar_system_memory_total_bytes * 100", "legendFormat": "{{ node_id }}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false, "axisLabel": "%", "drawStyle": "line",
            "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "never",
            "spanNulls": false, "stacking": { "mode": "none" }
          },
          "max": 100, "min": 0, "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Disk Usage % per Node",
      "type": "timeseries",
      "targets": [{ "expr": "pillar_system_disk_used_bytes / pillar_system_disk_total_bytes * 100", "legendFormat": "{{ node_id }}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false, "axisLabel": "", "drawStyle": "line",
            "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "never",
            "spanNulls": false, "stacking": { "mode": "none" }
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Network I/O (all nodes)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(pillar_system_network_rx_bytes[5m])", "legendFormat": "{{ node_id }} rx", "refId": "A" },
        { "expr": "rate(pillar_system_network_tx_bytes[5m])", "legendFormat": "{{ node_id }} tx", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["pillar", "solana", "fleet"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "Pillar Prometheus", "value": "pillar-prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Pillar Fleet Overview",
  "uid": "pillar-fleet-overview",
  "version": 1
