#!/usr/bin/env bash
set -euo pipefail
echo "=== Pillar: Provisioning Jito {{version}} on {{cluster}} ==="

# Install validator binary
DOWNLOAD_URL="{{download_url}}"
STAGING="/tmp/pillar-staging"
rm -rf "$STAGING"

if [ -n "$DOWNLOAD_URL" ]; then
  # Direct download: tarball or standalone binary
  mkdir -p "$STAGING"
  echo "Downloading..."
  curl -sSL -o "$STAGING/download" "$DOWNLOAD_URL"

  # SHA256 verification (skip if empty)
  SHA="{{sha256}}"
  if [ -n "$SHA" ]; then
    echo "$SHA  $STAGING/download" | sha256sum -c
    echo "SHA256 verified"
  fi

  # Handle tarball vs standalone binary
  if file "$STAGING/download" | grep -q "bzip2\|gzip\|tar"; then
    echo "Extracting tarball..."
    mkdir -p "$STAGING/extract"
    tar -xf "$STAGING/download" -C "$STAGING/extract"
    BINARY=$(find "$STAGING/extract" \( -name "jito-validator" -o -name "agave-validator" -o -name "solana-validator" \) -type f | head -1)
    if [ -z "$BINARY" ]; then
      echo "ERROR: validator binary not found in tarball" >&2
      exit 1
    fi
    sudo install -m 755 "$BINARY" {{binary_path}}
  else
    sudo install -m 755 "$STAGING/download" {{binary_path}}
  fi
else
  echo "ERROR: download_url is required for Jito client" >&2
  exit 1
fi
echo "Binary installed to {{binary_path}}"

# Stop existing service if running
sudo systemctl stop {{old_service_name}} 2>/dev/null || true

{{yellowstone_section}}

# Write systemd unit
sudo tee /etc/systemd/system/{{service_name}}.service > /dev/null <<'UNIT'
[Unit]
Description=Solana Validator (jito)
After=network.target
{{start_limit_line}}

[Service]
Type=simple
User=sol
ExecStart={{exec_start}}
Restart=on-failure
RestartSec={{restart_sec}}
LimitNOFILE=1000000
{{log_rate_limit_line}}
{{environment_lines}}

[Install]
WantedBy=multi-user.target
UNIT

sudo systemctl daemon-reload
sudo systemctl enable --now {{service_name}}
echo "Service {{service_name}} started"

# Update agent config
CONFIG="${PILLAR_AGENT_CONFIG:-/etc/pillar/agent.yaml}"
{{agent_config_sed_commands}}

# Restart agent for config reload
sudo systemctl restart pillar-agent
rm -rf "$STAGING"
echo "=== Provision complete ==="
