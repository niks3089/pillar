      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "process": true },
            "renameByName": {
              "Value #connected": "connected",
              "Value #latency": "latency ms",
              "Value #sent": "reports sent",
              "Value #failed": "reports failed",
              "Value #uptime": "uptime"
            }
          }
        }
