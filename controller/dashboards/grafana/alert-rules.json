  "Pillar": [
    {
      "name": "pillar-alerts",
      "interval": "1m",
      "rules": [
        {
          "expr": "",
          "for": "1m",
          "keep_firing_for": "0s",
          "labels": {
            "severity": "critical"
          },
          "annotations": {
            "description": "Node {{ $labels.node_id }} has been unreachable for more than 1 minute. The node may be down or the agent may have stopped reporting.",
            "summary": "Node {{ $labels.node_id }} is offline"
          },
          "grafana_alert": {
            "title": "Node Offline",
            "condition": "C",
            "data": [
              {
                "refId": "A",
                "queryType": "",
                "relativeTimeRange": {
                  "from": 300,
                  "to": 0
                },
                "datasourceUid": "pillar-prometheus",
                "model": {
                  "expr": "pillar_node_healthy == 0",
                  "instant": true,
                  "intervalMs": 1000,
                  "maxDataPoints": 43200,
                  "refId": "A"
                }
              },
              {
                "refId": "B",
                "queryType": "",
                "relativeTimeRange": {
                  "from": 300,
                  "to": 0
                },
                "datasourceUid": "__expr__",
                "model": {
                  "expression": "A",
                  "intervalMs": 1000,
                  "maxDataPoints": 43200,
                  "reducer": "last",
                  "refId": "B",
                  "type": "reduce"
                }
              },
              {
                "refId": "C",
                "queryType": "",
                "relativeTimeRange": {
                  "from": 300,
                  "to": 0
                },
                "datasourceUid": "__expr__",
                "model": {
                  "conditions": [
                    {
                      "evaluator": {
                        "params": [
                          0
                        ],
                        "type": "gt"
                      }
                    }
                  ],
                  "expression": "B",
                  "intervalMs": 1000,
                  "maxDataPoints": 43200,
                  "refId": "C",
                  "type": "threshold"
                }
              }
            ],
            "updated": "2026-02-20T16:08:08Z",
