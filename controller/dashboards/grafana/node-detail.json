      "targets": [
        { "expr": "pillar_node_local_slot{node_id=\"$node_id\"}", "legendFormat": "local slot", "refId": "A" },
        { "expr": "pillar_node_reference_slot{node_id=\"$node_id\"}", "legendFormat": "reference slot", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "System Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisLabel": "%", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "never", "spanNulls": false, "stacking": { "mode": "none" } },
          "max": 100, "min": 0, "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max", "mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "pillar_system_cpu_usage_percent{node_id=\"$node_id\"}", "legendFormat": "system", "refId": "A" },
        { "expr": "pillar_process_cpu_percent{node_id=\"$node_id\", process=\"validator\"}", "legendFormat": "validator", "refId": "B" },
        { "expr": "pillar_process_cpu_percent{node_id=\"$node_id\", process=\"agent\"}", "legendFormat": "agent", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisLabel": "", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "never", "spanNulls": false, "stacking": { "mode": "none" } },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "pillar_system_memory_used_bytes{node_id=\"$node_id\"}", "legendFormat": "system used", "refId": "A" },
        { "expr": "pillar_system_memory_total_bytes{node_id=\"$node_id\"}", "legendFormat": "system total", "refId": "B" },
        { "expr": "pillar_process_memory_bytes{node_id=\"$node_id\", process=\"validator\"}", "legendFormat": "validator", "refId": "C" },
        { "expr": "pillar_process_memory_bytes{node_id=\"$node_id\", process=\"agent\"}", "legendFormat": "agent", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisLabel": "", "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1, "pointSize": 5, "showPoints": "never", "spanNulls": false, "stacking": { "mode": "none" } },
          "unit": "bytes"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "total" }, "properties": [{ "id": "custom.fillOpacity", "value": 0 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Disk Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "pillar_system_disk_used_bytes{node_id=\"$node_id\"}", "legendFormat": "used", "refId": "A" },
        { "expr": "pillar_system_disk_total_bytes{node_id=\"$node_id\"}", "legendFormat": "total", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisLabel": "", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "pointSize": 5, "showPoints": "never", "spanNulls": false, "stacking": { "mode": "none" } },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Network I/O",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(pillar_system_network_rx_bytes{node_id=\"$node_id\"}[5m])", "legendFormat": "rx bytes/s", "refId": "A" },
        { "expr": "rate(pillar_system_network_tx_bytes{node_id=\"$node_id\"}[5m])", "legendFormat": "tx bytes/s", "refId": "B" }
      ]
    }
