        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Health Status",
      "type": "stat",
      "targets": [
        {
          "expr": "pillar_node_healthy{node_id=\"$node_id\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
