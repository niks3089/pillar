      "title": "Local Slot",
      "type": "stat",
      "targets": [{ "expr": "pillar_node_local_slot{node_id=\"$node_id\"}", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#2196f3", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 21,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "title": "Reference Slot",
      "type": "stat",
      "targets": [{ "expr": "pillar_node_reference_slot{node_id=\"$node_id\"}", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#2196f3", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 22,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "title": "Restarts",
      "type": "stat",
      "targets": [{ "expr": "pillar_node_restarts_total{node_id=\"$node_id\"}", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#4caf50", "value": null }, { "color": "#f44336", "value": 1 }] },
          "color": { "mode": "thresholds" },
          "mappings": [{ "options": { "0": { "text": "No" }, "1": { "text": "YES", "color": "#f44336" } }, "type": "value" }]
        },
        "overrides": []
