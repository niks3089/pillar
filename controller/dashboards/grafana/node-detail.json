{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Validator Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#f44336", "value": null }, { "color": "#4caf50", "value": 1 }] },
          "color": { "mode": "thresholds" },
          "mappings": [{ "options": { "0": { "text": "UNHEALTHY", "color": "#f44336" }, "1": { "text": "HEALTHY", "color": "#4caf50" } }, "type": "value" }]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "title": "Health Status",
      "type": "stat",
      "targets": [{ "expr": "pillar_node_healthy{node_id=\"$node_id\"}", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#4caf50", "value": null }, { "color": "#ffc107", "value": 50 }, { "color": "#f44336", "value": 200 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "title": "Slots Behind",
      "type": "stat",
      "targets": [{ "expr": "pillar_node_slots_behind{node_id=\"$node_id\"}", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#2196f3", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
