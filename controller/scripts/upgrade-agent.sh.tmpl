#!/usr/bin/env bash
set -euo pipefail
echo "=== Pillar: Upgrading pillar-agent to {{version}} ==="

# Download and verify binary
STAGING="/tmp/pillar-staging"
rm -rf "$STAGING" && mkdir -p "$STAGING"
echo "Downloading binary..."
curl -sSL -o "$STAGING/binary" "{{download_url}}"
echo "{{sha256}}  $STAGING/binary" | sha256sum -c

# Install new binary and restart (systemd Restart=always will pick up new binary)
sudo install -m 755 "$STAGING/binary" /usr/local/bin/pillar-agent
sudo systemctl restart pillar-agent

rm -rf "$STAGING"
echo "=== Agent upgrade complete ==="
